{
  "name": "@opensassi/deepenc-harness",
  "version": "0.0.1",
  "type": "module",
  "main": "./lib/index.js",
  "exports": "./lib/index.js",
  "bin": {
    "deepenc-harness": "./lib/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x lib/index.js && tsc -p dashboard/tsconfig.json",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "dashboard": "node lib/index.js dashboard",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "prepare": "npm run build"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "9.20.0",
    "@playwright/test": "^1.52.0",
    "@types/express": "^5.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "22.13.10",
    "@typescript-eslint/eslint-plugin": "8.18.1",
    "@typescript-eslint/parser": "8.18.1",
    "eslint": "9.20.0",
    "jest": "29.7.0",
    "prettier": "3.5.3",
    "ts-jest": "29.3.0",
    "typescript": "5.7.3"
  }
}
